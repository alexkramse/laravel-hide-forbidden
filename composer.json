{
    "name": "alexkramse/laravel-hide-forbidden",
    "description": "Hide all or selected Laravel 403 Forbidden responses behind 404 Not Found responses.",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "license": "MIT",
    "version": "1.0.2",
    "authors": [
        {
            "name": "Oleksandr Kramarenko",
            "email": "dev.kramarenko@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Alexkramse\\LaravelHideForbidden\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alexkramse\\LaravelHideForbidden\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0",
        "orchestra/testbench": "^10.0|^11.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alexkramse\\LaravelHideForbidden\\HideForbiddenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "config": {
        "allow-plugins": {
            "sort-packages": true,
            "optimize-autoloader": true,
            "pestphp/pest-plugin": true
        }
    }
}
